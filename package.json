{
  "name": "steam-launcher",
  "version": "1.0.0",
  "description": "Fullscreen Steam game launcher with gamepad support",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:web": "electron-builder --target dir",
    "build:appimage": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.damaru.steam-launcher",
    "productName": "Steam Launcher",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Game"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
